@{
    ViewData["Title"] = "IDEX PDF Tools - Home";
}

<style>
    /* ===== Hero ===== */
    .hero {
        background: linear-gradient(135deg, var(--primary) 0%, #01579b 60%, var(--secondary) 100%);
        color: white;
        padding: 80px 40px 72px;
        text-align: center;
        border-radius: var(--radius-xl);
        margin-bottom: 56px;
        position: relative;
        overflow: hidden;
    }

    .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }

    .hero-content { position: relative; z-index: 1; }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 100px;
        padding: 8px 20px;
        font-size: 0.8125rem;
        font-weight: 600;
        margin-bottom: 24px;
        letter-spacing: 0.03em;
    }

    .hero h1 {
        font-size: 3rem;
        font-weight: 800;
        margin: 0 0 16px;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .hero .hero-sub {
        font-size: 1.125rem;
        opacity: 0.9;
        max-width: 560px;
        margin: 0 auto 32px;
        line-height: 1.7;
        font-weight: 400;
    }

    .hero-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .hero-actions .btn-hero {
        padding: 14px 32px;
        border-radius: var(--radius-md);
        font-weight: 700;
        font-size: 0.9375rem;
        text-decoration: none;
        transition: var(--transition);
    }

    .btn-hero-primary {
        background: white;
        color: var(--primary);
    }

    .btn-hero-primary:hover {
        background: var(--gray-100);
        color: var(--primary-dark);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }

    .btn-hero-outline {
        background: transparent;
        color: white;
        border: 2px solid rgba(255,255,255,0.4);
    }

    .btn-hero-outline:hover {
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.7);
        color: white;
        transform: translateY(-2px);
    }

    /* ===== Features ===== */
    .section-label {
        text-align: center;
        margin-bottom: 40px;
    }

    .section-label .overline {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--primary);
        margin-bottom: 8px;
    }

    .section-label h2 {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--gray-900);
        letter-spacing: -0.025em;
        margin: 0;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 24px;
        margin-bottom: 64px;
    }

    .feature-card {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg);
        padding: 32px 28px;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

    .feature-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--primary), var(--secondary));
        opacity: 0;
        transition: var(--transition);
    }

    .feature-card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateY(-4px);
        border-color: var(--gray-300);
    }

    .feature-card:hover::before { opacity: 1; }

    .feature-card .card-icon {
        width: 56px;
        height: 56px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 20px;
    }

    .feature-card .card-icon.icon-split {
        background: #fff3e0; color: #e65100;
    }
    .feature-card .card-icon.icon-merge {
        background: #e3f2fd; color: #0d47a1;
    }
    .feature-card .card-icon.icon-edit {
        background: #e0f2f1; color: #00695c;
    }

    .feature-card h3 {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--gray-900);
        margin: 0 0 10px;
    }

    .feature-card p {
        color: var(--gray-500);
        font-size: 0.9rem;
        line-height: 1.65;
        margin: 0 0 20px;
    }

    .feature-card .card-link {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--primary);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--transition);
    }

    .feature-card .card-link:hover {
        color: var(--primary-dark);
        gap: 10px;
    }

    /* ===== How It Works ===== */
    .how-section {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg);
        padding: 48px 40px;
        margin-bottom: 64px;
    }

    .steps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 32px;
        margin-top: 36px;
    }

    .step {
        text-align: center;
        position: relative;
    }

    .step-num {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--primary-50);
        color: var(--primary);
        font-weight: 800;
        font-size: 1.125rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

    .step h4 {
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--gray-800);
        margin: 0 0 8px;
    }

    .step p {
        font-size: 0.8125rem;
        color: var(--gray-500);
        line-height: 1.6;
        margin: 0;
    }

    /* ===== Stats Bar ===== */
    .stats-bar {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 20px;
        margin-bottom: 48px;
    }

    .stat-item {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-md);
        padding: 24px 20px;
        text-align: center;
    }

    .stat-item .stat-icon {
        color: var(--primary);
        font-size: 1.25rem;
        margin-bottom: 10px;
    }

    .stat-item .stat-label {
        font-size: 0.8125rem;
        color: var(--gray-500);
        font-weight: 500;
    }

    .stat-item .stat-value {
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--gray-800);
        margin-top: 4px;
    }
</style>

<!-- Hero -->
<div class="hero fade-in">
    <div class="hero-content">
        <div class="hero-badge">
            <i class="fas fa-building"></i> IDEX Internal PDF Tools
        </div>
        <h1>PDF Tools for<br>IDEX Teams</h1>
        <p class="hero-sub">
            Split, merge, and edit PDF documents securely — built for IDEX employees.
            All processing stays on our servers. No third-party services.
        </p>
        <div class="hero-actions">
            <a href="/Split" class="btn-hero btn-hero-primary"><i class="fas fa-scissors"></i>&nbsp; Split PDF</a>
            <a href="/Merge" class="btn-hero btn-hero-outline"><i class="fas fa-layer-group"></i>&nbsp; Merge PDFs</a>
        </div>
    </div>
</div>

<!-- Stats -->
<div class="stats-bar fade-in">
    <div class="stat-item">
        <div class="stat-icon"><i class="fas fa-shield-halved"></i></div>
        <div class="stat-label">Security</div>
        <div class="stat-value">Enterprise-grade</div>
    </div>
    <div class="stat-item">
        <div class="stat-icon"><i class="fas fa-bolt"></i></div>
        <div class="stat-label">Speed</div>
        <div class="stat-value">Instant Results</div>
    </div>
    <div class="stat-item">
        <div class="stat-icon"><i class="fas fa-server"></i></div>
        <div class="stat-label">Infrastructure</div>
        <div class="stat-value">IDEX Hosted</div>
    </div>
    <div class="stat-item">
        <div class="stat-icon"><i class="fas fa-lock"></i></div>
        <div class="stat-label">Access</div>
        <div class="stat-value">Internal Only</div>
    </div>
</div>

<!-- Features -->
<div class="section-label">
    <div class="overline">Tools</div>
    <h2>Everything your team needs for PDFs</h2>
</div>

<div class="features-grid fade-in">
    <div class="feature-card">
        <div class="card-icon icon-split"><i class="fas fa-scissors"></i></div>
        <h3>Split PDF</h3>
        <p>Extract specific pages from your PDF. Preview every page with real thumbnails and pick exactly what you need.</p>
        <a href="/Split" class="card-link">Get Started <i class="fas fa-arrow-right"></i></a>
    </div>
    <div class="feature-card">
        <div class="card-icon icon-merge"><i class="fas fa-layer-group"></i></div>
        <h3>Merge PDFs</h3>
        <p>Combine multiple PDF files into one document. Drag and drop to arrange them in your preferred order.</p>
        <a href="/Merge" class="card-link">Get Started <i class="fas fa-arrow-right"></i></a>
    </div>
    <div class="feature-card">
        <div class="card-icon icon-edit"><i class="fas fa-pen-ruler"></i></div>
        <h3>Edit PDF</h3>
        <p>Rotate individual pages, preview changes in real-time, and download your edited document instantly.</p>
        <a href="/Edit" class="card-link">Get Started <i class="fas fa-arrow-right"></i></a>
    </div>
</div>

<!-- How It Works -->
<div class="how-section fade-in">
    <div class="section-label" style="margin-bottom: 0;">
        <div class="overline">Simple Workflow</div>
        <h2>How it works</h2>
    </div>
    <div class="steps-grid">
        <div class="step">
            <div class="step-num">1</div>
            <h4>Upload</h4>
            <p>Drag &amp; drop or browse to select your PDF files</p>
        </div>
        <div class="step">
            <div class="step-num">2</div>
            <h4>Preview</h4>
            <p>See real page thumbnails and choose your action</p>
        </div>
        <div class="step">
            <div class="step-num">3</div>
            <h4>Customize</h4>
            <p>Select pages, reorder, rotate — whatever you need</p>
        </div>
        <div class="step">
            <div class="step-num">4</div>
            <h4>Download</h4>
            <p>Get your processed PDF instantly, ready to use</p>
        </div>
    </div>
</div>

